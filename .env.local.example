# .env.local.example
# Copy this to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Supabase ────────────────────────────────────────────────────────────
# These two are safe to expose client-side (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# SERVICE ROLE KEY: server-side ONLY. Never in a NEXT_PUBLIC_ variable.
# Used by: API routes, sync_to_supabase.py, admin operations.
# If this key appears in a browser bundle, it is a CRITICAL security failure.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Anthropic ───────────────────────────────────────────────────────────
# Server-side ONLY. The founding session API route uses this key.
# Never reference this in a React component or client-side hook.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── App ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Rate limiting (Upstash Redis) ───────────────────────────────────────
# Optional for local development; required for production deployments.
# Create a free Redis database at upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# ── Staging vs Production ────────────────────────────────────────────────
# STAGING:    Use squadvault-staging Supabase project URL + anon key
# PRODUCTION: Use squadvault-prod Supabase project URL + anon key
# The databases are separate. Never mix staging and production data.
NODE_ENV=development
